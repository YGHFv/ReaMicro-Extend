<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <queries>
        <package android:name="app.zhendong.reamicro" />
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:description="@string/module_description"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/module_name"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true">
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:resource="@string/module_description" />
        <meta-data
            android:name="xposedminversion"
            android:value="101" />
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />
        <meta-data
            android:name="lyricon_module"
            android:value="true" />
        <meta-data
            android:name="lyricon_module_author"
            android:value="ReaMicro Extend" />
        <meta-data
            android:name="lyricon_module_description"
            android:value="Send ReaMicro read-aloud captions to Lyricon" />

        <receiver
            android:name=".notification.OnlineCompletionNotificationReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.reamicro.fix.ONLINE_COMPLETION_NOTIFICATION" />
                <action android:name="com.reamicro.fix.ONLINE_COMPLETION_CANCEL" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".tts.ReadAloudCommandReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.reamicro.fix.READ_ALOUD_PREPARE" />
                <action android:name="com.reamicro.fix.READ_ALOUD_APPEND" />
                <action android:name="com.reamicro.fix.READ_ALOUD_PLAY" />
                <action android:name="com.reamicro.fix.READ_ALOUD_PAUSE" />
                <action android:name="com.reamicro.fix.READ_ALOUD_RESUME" />
                <action android:name="com.reamicro.fix.READ_ALOUD_STOP" />
                <action android:name="com.reamicro.fix.READ_ALOUD_PREV" />
                <action android:name="com.reamicro.fix.READ_ALOUD_NEXT" />
                <action android:name="com.reamicro.fix.READ_ALOUD_SYNC_PROGRESS" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".notification.OnlineCompletionNotificationActivity"
            android:enabled="true"
            android:excludeFromRecents="true"
            android:exported="true"
            android:theme="@style/NoDisplayTheme" />

        <activity
            android:name=".importer.SourceImportActivity"
            android:enabled="true"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/module_name"
            android:theme="@style/NoDisplayTheme">
            <intent-filter android:label="@string/module_name">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/json" />
            </intent-filter>
            <intent-filter android:label="@string/module_name">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.json" />
            </intent-filter>
            <intent-filter android:label="@string/module_name">
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/json" />
            </intent-filter>
        </activity>

        <activity
            android:name=".tts.ReadAloudCommandActivity"
            android:enabled="true"
            android:excludeFromRecents="true"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/NoDisplayTheme" />


        <service
            android:name=".notification.OnlineCompletionNotificationService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".tts.ReadAloudService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback" />
    </application>
</manifest>
